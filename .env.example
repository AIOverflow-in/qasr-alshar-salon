# ============================================================================
# Qasr Alshar Salon — Environment template. Copy to .env and fill in values.
# ============================================================================

# --- Database (Neon Postgres) ---
# Pooled connection (runtime). DIRECT_URL is the non-pooled host for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://your-site.netlify.app"
NEXT_PUBLIC_WHATSAPP_NUMBER="+971500000000"

# --- OpenAI (auto blog + image generation) ---
OPENAI_API_KEY="sk-..."
OPENAI_BLOG_MODEL="gpt-4.1"

# --- Email (Resend) ---
RESEND_API_KEY="re_..."
FROM_EMAIL="Qasr Alshar Salon <onboarding@resend.dev>"
SALON_NOTIFICATION_EMAIL="salon-inbox@example.com"

# --- Admin dashboard ---
ADMIN_EMAIL="admin@qasralshar.ae"
ADMIN_PASSWORD_HASH="$2b$10$replace_with_bcrypt_hash"
AUTH_SECRET="generate_with_openssl_rand_hex_32"

# --- Cron protection (blog auto-generation) ---
CRON_SECRET="generate_a_random_string"
