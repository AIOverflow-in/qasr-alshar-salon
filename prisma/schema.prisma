// Qasr Alshar Salon — data model
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String
  categorySlug String
  priceAED    Int
  durationMin Int      @default(60)
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]

  @@index([categorySlug])
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Booking {
  id           String        @id @default(cuid())
  // denormalized service info (survives service edits/deletes)
  serviceId    String?
  serviceName  String
  priceAED     Int
  durationMin  Int

  customerName String
  email        String
  phone        String
  notes        String?

  startAt      DateTime
  endAt        DateTime
  status       BookingStatus @default(CONFIRMED)

  locale       String        @default("en")
  // ERP: which Crown Artist + how the booking came in
  staffId      String?
  source       String        @default("ONLINE") // ONLINE | WALKIN | PHONE | WHATSAPP
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  staff        Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([startAt])
  @@index([status])
  @@index([staffId])
}

/// Weekly opening hours. weekday: 0 = Sunday … 6 = Saturday.
model WorkingHours {
  id      String  @id @default(cuid())
  weekday Int     @unique
  open    String  @default("10:00") // HH:mm
  close   String  @default("22:00")
  closed  Boolean @default(false)
}

/// Admin-defined blocked windows (holidays, days off, private events).
model BlockedSlot {
  id      String   @id @default(cuid())
  startAt DateTime
  endAt   DateTime
  reason  String?
  createdAt DateTime @default(now())

  @@index([startAt])
}

/// Singleton settings row (id = "singleton").
model SalonSettings {
  id              String @id @default("singleton")
  capacity        Int    @default(3)  // concurrent appointments (stations)
  slotMinutes     Int    @default(30) // granularity of bookable slots
  leadTimeMinutes Int    @default(60) // min notice before a booking
  maxAdvanceDays  Int    @default(60) // how far ahead booking is allowed
  updatedAt       DateTime @updatedAt
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum PostSource {
  AI
  MANUAL
}

model BlogPost {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String
  metaDescription String
  contentMarkdown String     @db.Text
  tags            String[]   @default([])
  heroImage       String?
  category        String     @default("Beauty Tips")
  readingMinutes  Int        @default(4)
  status          PostStatus @default(PUBLISHED)
  source          PostSource @default(AI)
  publishedAt     DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
}

/// Rotating pool of topics/keywords for the AI blog generator.
model BlogTopic {
  id        String    @id @default(cuid())
  title     String
  keywords  String[]  @default([])
  used      Boolean   @default(false)
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RECEPTION
  STYLIST
  INVESTOR
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Admin")
  role         Role     @default(SUPER_ADMIN)
  staffId      String?  // optional link to a Staff record (for STYLIST logins)
  createdAt    DateTime @default(now())
}

/// Salon team member ("Crown Artist", reception, etc.). Seeded from STAFF INFORMATION.xlsx.
model Staff {
  id         String     @id @default(cuid())
  name       String
  role       String     @default("Crown Artist")
  hours      String     @default("10:00AM - 10:00PM")
  offDay     String?    // e.g. "Mondays"
  // commission config
  commissionPct Int     @default(40) // stylist sales split %
  referralPct   Int     @default(5)
  active     Boolean    @default(true)
  order      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  bookings   Booking[]

  @@index([active])
}

/// Salon client / CRM record.
model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  hairType  String?  // e.g. 4C, low-porosity
  notes     String?
  visits    Int      @default(0)
  totalSpentAED Int   @default(0)
  consentMarketing Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
}

/// Inventory product (barcoded) + retail/aftercare item. Seeded from inventory sheets.
model Product {
  id        String   @id @default(cuid())
  barcode   String?
  name      String
  category  String   @default("Retail / Aftercare")
  qty       Int      @default(0)
  reorderAt Int      @default(3)
  costAED   Int?
  saleAED   Int?
  retail    Boolean  @default(false) // show in e-commerce/aftercare
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([barcode])
}
