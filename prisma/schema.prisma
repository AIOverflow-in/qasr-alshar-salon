// Qasr Alshar Salon — data model
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String
  categorySlug String
  priceAED    Int
  durationMin Int      @default(60)
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]

  @@index([categorySlug])
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Booking {
  id           String        @id @default(cuid())
  // denormalized service info (survives service edits/deletes)
  serviceId    String?
  serviceName  String
  priceAED     Int
  durationMin  Int

  customerName String
  email        String
  phone        String
  notes        String?

  startAt      DateTime
  endAt        DateTime
  status       BookingStatus @default(CONFIRMED)

  locale       String        @default("en")
  // ERP: which Crown Artist + how the booking came in
  staffId      String?
  clientId     String?       // links the booking to a CRM Client (auto-created on booking)
  source       String        @default("ONLINE") // ONLINE | WALKIN | PHONE | WHATSAPP
  // service delivery: at the salon vs. home/clinic visit (needs salon confirmation)
  serviceMode   String       @default("SALON") // SALON | HOME
  address       String?      // home-service address (when serviceMode = HOME)
  customRequest String?      // free-text request when the client can't find a service
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  staff        Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  salesOrders  SalesOrder[]
  items        BookingItem[]

  @@index([startAt])
  @@index([status])
  @@index([staffId])
  @@index([createdAt])
}

/// Weekly opening hours. weekday: 0 = Sunday … 6 = Saturday.
model WorkingHours {
  id      String  @id @default(cuid())
  weekday Int     @unique
  open    String  @default("10:00") // HH:mm
  close   String  @default("22:00")
  closed  Boolean @default(false)
}

/// Admin-defined blocked windows (holidays, days off, private events).
model BlockedSlot {
  id      String   @id @default(cuid())
  startAt DateTime
  endAt   DateTime
  reason  String?
  createdAt DateTime @default(now())

  @@index([startAt])
}

/// Singleton settings row (id = "singleton").
model SalonSettings {
  id              String @id @default("singleton")
  capacity        Int    @default(3)  // concurrent appointments (stations)
  slotMinutes     Int    @default(30) // granularity of bookable slots
  leadTimeMinutes Int    @default(60) // min notice before a booking
  maxAdvanceDays  Int    @default(60) // how far ahead booking is allowed
  updatedAt       DateTime @updatedAt
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum PostSource {
  AI
  MANUAL
}

model BlogPost {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String
  metaDescription String
  contentMarkdown String     @db.Text
  tags            String[]   @default([])
  heroImage       String?
  category        String     @default("Beauty Tips")
  readingMinutes  Int        @default(4)
  status          PostStatus @default(PUBLISHED)
  source          PostSource @default(AI)
  publishedAt     DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
}

/// Rotating pool of topics/keywords for the AI blog generator.
model BlogTopic {
  id        String    @id @default(cuid())
  title     String
  keywords  String[]  @default([])
  used      Boolean   @default(false)
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  RECEPTION
  STYLIST
  INVESTOR
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Admin")
  role         Role     @default(SUPER_ADMIN)
  staffId      String?  // optional link to a Staff record (for STYLIST logins)
  createdAt    DateTime @default(now())
}

/// Salon team member ("Crown Artist", reception, etc.). Seeded from STAFF INFORMATION.xlsx.
model Staff {
  id         String     @id @default(cuid())
  name       String
  role       String     @default("Crown Artist")
  hours      String     @default("10:00AM - 10:00PM")
  offDay     String?    // e.g. "Mondays"
  // commission config
  commissionPct Int     @default(40) // stylist sales split %
  referralPct   Int     @default(5)
  active     Boolean    @default(true)
  order      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  bookings    Booking[]
  salesOrders SalesOrder[]

  @@index([active])
}

/// Salon client / CRM record.
model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  hairType  String?  // e.g. 4C, low-porosity
  notes     String?
  visits    Int      @default(0)
  totalSpentAED Int   @default(0)
  consentMarketing Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesOrders SalesOrder[]
  bookings    Booking[]

  @@index([phone])
  @@index([email])
}

/// Inventory product (barcoded) + retail/aftercare item. Seeded from inventory sheets.
model Product {
  id        String   @id @default(cuid())
  barcode   String?
  name      String
  category  String   @default("Retail / Aftercare")
  qty       Int      @default(0)
  reorderAt Int      @default(3)
  costAED   Int?
  saleAED   Int?
  retail    Boolean  @default(false) // show in e-commerce/aftercare
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderLines     OrderLine[]
  stockMovements StockMovement[]

  @@index([category])
  @@index([barcode])
}

enum OrderStatus {
  DRAFT
  PAID
  VOIDED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

/// POS invoice / sales order — ties services + products to a stylist + client.
model SalesOrder {
  id            String        @id @default(cuid())
  invoiceNo     String        @unique
  status        OrderStatus   @default(DRAFT)
  paymentMethod PaymentMethod @default(CASH)

  // optional links
  bookingId     String?
  clientId      String?
  staffId       String?
  marketerId    String?       // Staff who referred this client (gets a referral %)
  marketerPct   Int           @default(5)

  // idempotency: one cart submit = one order, even if the request is retried
  clientRequestId String?     @unique

  subtotalAED   Int           @default(0)
  vatPct        Int           @default(5)
  vatAED        Int           @default(0)
  totalAED      Int           @default(0)
  notes         String?

  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines         OrderLine[]
  booking       Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  staff         Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([staffId])
  @@index([createdAt])
  @@index([bookingId])
}

/// One service within a multi-service booking. Booking keeps summary totals; items hold the detail.
model BookingItem {
  id          String   @id @default(cuid())
  bookingId   String
  serviceId   String?
  serviceName String
  priceAED    Int
  durationMin Int
  staffId     String?  // preferred artist for this specific service
  createdAt   DateTime @default(now())

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model OrderLine {
  id          String     @id @default(cuid())
  orderId     String
  kind        String     @default("SERVICE") // SERVICE | PRODUCT
  description String
  qty         Int        @default(1)
  unitAED     Int
  lineAED     Int
  staffId     String?    // legacy single artist (kept for back-compat)
  staffIds    String[]   @default([]) // Crown Artists who performed THIS line (commission splits equally)

  productId   String?
  product     Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  order       SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum MovementKind {
  STOCK_IN
  STOCK_OUT
  SALE
  ADJUSTMENT
}

/// Inventory audit trail — every qty change recorded here.
model StockMovement {
  id        String       @id @default(cuid())
  productId String
  kind      MovementKind
  qty       Int          // positive = in, negative = out
  note      String?
  staffId   String?
  createdAt DateTime     @default(now())

  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
}

/// Commission record per stylist per sales order.
model Commission {
  id          String   @id @default(cuid())
  staffId     String
  orderId     String
  type        String   @default("SALES_SPLIT") // SALES_SPLIT | REFERRAL | INCENTIVE
  baseAED     Int
  pct         Int
  amountAED   Int
  paid        Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([staffId])
  @@index([orderId])
  @@index([paid])
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARIES
  VISA
  SUPPLIES
  MARKETING
  MAINTENANCE
  OTHER
}

/// Operating expense entry — feeds the finance P&L + dividend calculation.
model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory @default(OTHER)
  description String
  amountAED   Int
  incurredOn  DateTime        @default(now())
  recurring   Boolean         @default(false) // monthly recurring (rent, salaries)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([incurredOn])
  @@index([category])
}

/// Capital / investment entry — investor contributions tracked against dividends.
model CapitalEntry {
  id            String   @id @default(cuid())
  investor      String
  amountAED     Int
  contributedOn DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([contributedOn])
}
